# ── Copy this to .env and fill in real values ──────────────────

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app,yourdomain.co.zw

# PostgreSQL (e.g. from Supabase, Neon, Railway, or local)
DATABASE_URL=postgresql://user:password@host:5432/lightworld_db

# Backblaze B2 Storage
USE_B2_STORAGE=False
B2_KEY_ID=your-key-id
B2_APPLICATION_KEY=your-application-key
B2_BUCKET_NAME=lightworld-media
B2_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com
B2_REGION=us-west-002

# Gmail SMTP
EMAIL_HOST_USER=engineeringlightworld@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=Light World Engineering <engineeringlightworld@gmail.com>
ADMIN_EMAIL=engineeringlightworld@gmail.com

# Google Analytics
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
